ainer:latest'\n    output:\n        \"fitDiagnosticsTest.root\"\n    shell:\n        \"\"\"\n        APPTAINER_SHELL=$(which bash) apptainer exec -B .:/home/cmsusr/analysis \\\n            -B /cvmfs --pwd /home/cmsusr/analysis/  \\\n            {input.container} \\\n                /bin/bash -c \"export LANG=C && export LC_ALL=C && \\\n                source /cvmfs/cms.cern.ch/cmsset_default.sh && \\\n                cd /home/cmsusr/CMSSW_14_1_0_pre4/ && \\\n                 cmsenv && \\\n                 cd - && \\\n                text2workspace.py {input.card} -m 125 -o workspace.root && \\\n                combine -M FitDiagnostics workspace.root --saveShapes --saveWithUncertainties\"\n        \"\"\"","position":{"start":{"line":140,"column":1},"end":{"line":162,"column":1}},"key":"MVlJNmMATv"},{"type":"heading","depth":3,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"The Grand Finale","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"nfNeb3UMFZ"}],"identifier":"the-grand-finale","label":"The Grand Finale","html_id":"the-grand-finale","implicit":true,"key":"bR5tQTQD1R"},{"type":"paragraph","position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"text","value":"Now, define your target in rule all:","position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"key":"jKPst9n1G9"}],"key":"ZUWLeyIUUm"},{"type":"code","lang":"python","value":"rule all:\n    input:\n        \"fitDiagnosticsTest.root\"","position":{"start":{"line":168,"column":1},"end":{"line":172,"column":1}},"key":"Vm5wucYqFN"},{"type":"paragraph","position":{"start":{"line":174,"column":1},"end":{"line":174,"column":1}},"children":[{"type":"text","value":"Run it!","position":{"start":{"line":174,"column":1},"end":{"line":174,"column":1}},"key":"CQAocQZHAc"}],"key":"Kgh3WFbU9V"},{"type":"code","lang":"bash","value":"pixi run snakemake --cores 4 --use-appt